# ClipFlow — environment. Copy to `.env` and fill in.
#   cp .env.example .env
# Real shell env vars always win over this file. `.env` is gitignored.

# ---- server ----
# Railway injects PORT automatically; locally 4400.
PORT=4400
# The public URL of the app. Locally http://localhost:4400; on Railway the
# public app URL (e.g. https://clipflow-production.up.railway.app).
BASE_URL=http://localhost:4400
# Leave blank to auto-generate an ephemeral secret (sessions reset on restart).
# Set a long random string in production to keep sessions across restarts.
SESSION_SECRET=

# ---- Zernio (posting backend — API key from the zernio.com dashboard) ----
ZERNIO_API_KEY=

# ---- Gemini (optional — unlocks the AI Show Covers studio) ----
# Free key from aistudio.google.com (image models need billing on the Google
# project). Blank = studio shows a locked state.
GEMINI_API_KEY=
# Daily cover-generation cap per seller (default 10).
THUMBS_PER_DAY=10
# 1 = run the vision QA loop on generated backgrounds (default on). 0 = off.
THUMBS_QA=1

# ---- Stripe billing (optional — blank = trials never expire, dev mode) ----
# Dashboard -> Developers -> API keys. Price: create "ClipFlow Pro" $19/mo
# recurring, paste its price id. Webhook endpoint: <BASE_URL>/webhooks/stripe
# with events: checkout.session.completed, customer.subscription.updated,
# customer.subscription.deleted, invoice.payment_failed.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID=

# ---- Email via Resend (optional — blank = emails print to the console) ----
RESEND_API_KEY=
MAIL_FROM=ClipFlow <hello@yourdomain.com>

# ---- Admin ----
# The account with this email gets the /admin page.
ADMIN_EMAIL=

# ---- engine ----
WN_POLL_SECONDS=300
# 1 = simulate posting (log payloads, post nothing). 0 = post for real.
WN_DRY_RUN=0
# Where JSON stores + downloaded clips live. On Railway point both under the
# persistent volume, e.g. WN_DATA_DIR=/data and WN_CLIPS_DIR=/data/clips.
WN_DATA_DIR=./data
WN_CLIPS_DIR=./clips
